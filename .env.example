OPENROUTER_API_KEY=sk-or-v1-xxx
NEXT_PUBLIC_APP_URL=https://interview.infinityhirecopilot.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infinityhire_copilot
AUTH_SECRET=change-me-in-production
# Optional CA certificate for strict Postgres TLS verification in production.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Emergency-only escape hatch to bypass TLS cert verification (do not use in steady state).
# DATABASE_SSL_ALLOW_INSECURE=false
# Comma-separated emails allowed to call GET /api/analytics/funnel in production. Unset in dev = any logged-in user.
# ANALYTICS_ADMIN_EMAILS=you@company.com
# Allow mock POST /api/billing/upgrade when NODE_ENV=production (default off; CI sets this for prod E2E)
# ALLOW_MOCK_UPGRADE=true
#
# Stripe (production checkout). Webhook URL: POST {NEXT_PUBLIC_APP_URL}/api/billing/webhook
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_ID_PRO_MONTHLY=price_xxx
